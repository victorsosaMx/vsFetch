{
  "palette": {
    "bg": "#0d0d0d",
    "bg_header": "#141414",
    "border": "#262626",
    "text": "#e6e6e6",
    "text_dim": "#8c8c8c",
    "text_mid": "#b3b3b3",
    "accent": "#ffea00",
    "ok": "#4caf50",
    "mid": "#ffd600",
    "hi": "#fff176",
    "btn_github": "#ffea00",
    "btn_github_hover": "#ffeb3b",
    "btn_web": "#fbc02d",
    "btn_web_hover": "#ffeb3b"
  },
  "font": "JetBrainsMono Nerd Font",
  "font_sizes": {
    "title": 20,
    "body": 13,
    "small": 11
  },
  "logo": {
    "size": 56,
    "override": "",
    "sidebar_position": "top"
  },
  "default_mode": "full",
  "sections": [
    "hardware",
    "desktop",
    "terminal",
    "development",
    "uptime"
  ],
  "chassis": "",
  "dev_tools": [
    {
      "icon": "󱘗",
      "name": "Rust",
      "cmd": "rustc --version 2>/dev/null | awk '{print $2}'"
    },
    {
      "icon": "󰙱",
      "name": "Clang",
      "cmd": "clang --version 2>/dev/null | grep -oP 'version [0-9.]+' | awk '{print $2}'"
    },
    {
      "icon": "󰎙",
      "name": "NodeJS",
      "cmd": "node --version 2>/dev/null"
    },
    {
      "icon": "󰟓",
      "name": "Go",
      "cmd": "go version 2>/dev/null | awk '{print $3}' | tr -d go"
    },
    {
      "icon": "󰪳",
      "name": ".NET",
      "cmd": "dotnet --version 2>/dev/null"
    },
    {
      "icon": "󰨞",
      "name": "Editor",
      "cmd": "code --version 2>/dev/null | head -1"
    },
    {
      "icon": "󰊢",
      "name": "Git",
      "cmd": "git --version 2>/dev/null | awk '{print $3}'"
    }
  ],
  "window": {
    "width": 700,
    "height_mini": 380,
    "height_full": 680
  },
  "gradient_bar": {
    "enabled": false,
    "color_a": "#89b4fa",
    "color_b": "#f38ba8"
  },
  "layout": "left",
  "bg_image": {
    "path": "",
    "size": 300,
    "opacity": 0.75,
    "enabled": true
  },
  "animation": {
    "enabled": true,
    "type": "matrix",
    "scope": "full",
    "color": "#ffea00",
    "opacity": 0.25,
    "speed": 1.5,
    "drops": 65
  }
}
