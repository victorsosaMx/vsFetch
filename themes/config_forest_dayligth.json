  "logo": {
    "size": 56,
    "override": "",
    "sidebar_position": "bottom"
  },
  "default_mode": "full",
  "sections": [
    "hardware",
    "desktop",
    "terminal",
    "development",
    "uptime"
  ],
  "chassis": "",
  "dev_tools": [
    {
      "icon": "󱘗",
      "name": "Rust",
      "cmd": "rustc --version 2>/dev/null | awk '{print $2}'"
    },
    {
      "icon": "󰙱",
      "name": "Clang",
      "cmd": "clang --version 2>/dev/null | grep -oP 'version [0-9.]+' | awk '{print $2}'"
    },
    {
      "icon": "󰎙",
      "name": "NodeJS",
      "cmd": "node --version 2>/dev/null"
    },
    {
      "icon": "󰟓",
      "name": "Go",
      "cmd": "go version 2>/dev/null | awk '{print $3}' | tr -d go"
    },
    {
      "icon": "󰪳",
      "name": ".NET",
      "cmd": "dotnet --version 2>/dev/null"
    },
    {
      "icon": "󰨞",
      "name": "Editor",
      "cmd": "code --version 2>/dev/null | head -1"
    },
    {
      "icon": "󰊢",
      "name": "Git",
      "cmd": "git --version 2>/dev/null | awk '{print $3}'"
    }
  ],
  "window": {
    "width": 700,
    "height_mini": 380,
    "height_full": 680
  },
  "gradient_bar": {
    "enabled": false,
    "color_a": "#89b4fa",
    "color_b": "#f38ba8"
  },
  "layout": "top",
  "bg_image": {
    "path": "",
    "size": 300,
    "opacity": 0.75,
    "enabled": true
  },
  "animation": {
    "enabled": true,
    "type": "snow",
    "scope": "body",
    "color": "#3a7d44",
    "opacity": 0.18,
    "speed": 0.5,
    "drops": 55
  }
}
