{
  "palette": {
    "bg": "#eaf4fc",
    "bg_header": "#d4ebf9",
    "border": "#bcdff2",
    "text": "#1c1c1c",
    "text_dim": "#6b6b6b",
    "text_mid": "#3f3f3f",
    "accent": "#0088cc",
    "ok": "#4caf50",
    "mid": "#81d4fa",
    "hi": "#00acc1",
    "btn_github": "#0088cc",
    "btn_github_hover": "#0099dd",
    "btn_web": "#005f87",
    "btn_web_hover": "#007ab8"
  },
  "font": "JetBrainsMono Nerd Font",
  "font_sizes": {
    "title": 20,
    "body": 13,
    "small": 11
  },
  "logo": {
    "size": 56,
    "override": "",
    "sidebar_position": "bottom"
  },
  "default_mode": "full",
  "sections": [
    "hardware",
    "desktop",
    "terminal",
    "development",
    "uptime"
  ],
  "chassis": "",
  "dev_tools": [
    {
      "icon": "󱘗",
      "name": "Rust",
      "cmd": "rustc --version 2>/dev/null | awk '{print $2}'"
    },
    {
      "icon": "󰙱",
      "name": "Clang",
      "cmd": "clang --version 2>/dev/null | grep -oP 'version [0-9.]+' | awk '{print $2}'"
    },
    {
      "icon": "󰎙",
      "name": "NodeJS",
      "cmd": "node --version 2>/dev/null"
    },
    {
      "icon": "󰟓",
      "name": "Go",
      "cmd": "go version 2>/dev/null | awk '{print $3}' | tr -d go"
    },
    {
      "icon": "󰪳",
      "name": ".NET",
      "cmd": "dotnet --version 2>/dev/null"
    },
    {
      "icon": "󰨞",
      "name": "Editor",
      "cmd": "code --version 2>/dev/null | head -1"
    },
    {
      "icon": "󰊢",
      "name": "Git",
      "cmd": "git --version 2>/dev/null | awk '{print $3}'"
    }
  ],
  "window": {
    "width": 700,
    "height_mini": 380,
    "height_full": 680
  },
  "gradient_bar": {
    "enabled": true,
    "color_a": "#0088cc",
    "color_b": "#00acc1"
  },
  "layout": "top",
  "bg_image": {
    "path": "",
    "size": 300,
    "opacity": 0.75,
    "enabled": true
  },
  "animation": {
    "enabled": true,
    "type": "snow",
    "scope": "full",
    "color": "#0088cc",
    "opacity": 0.22,
    "speed": 1.1,
    "drops": 180
  }
}
