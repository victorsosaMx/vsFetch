{
  "palette": {
    "bg": "#fff7f9",
    "bg_header": "#ffeaf2",
    "border": "#f8d9e0",
    "text": "#3b2c3a",
    "text_dim": "#9b7f8f",
    "text_mid": "#7a5668",
    "accent": "#ff6f91",
    "ok": "#81c784",
    "mid": "#ffb6c1",
    "hi": "#ff4081",
    "btn_github": "#ff6f91",
    "btn_github_hover": "#f06292",
    "btn_web": "#ff85a2",
    "btn_web_hover": "#ff6f91"
  },
  "font": "JetBrainsMono Nerd Font",
  "font_sizes": {
    "title": 20,
    "body": 13,
    "small": 11
  },
  "logo": {
    "size": 56,
    "override": "",
    "sidebar_position": "bottom"
  },
  "default_mode": "full",
  "sections": [
    "hardware",
    "desktop",
    "terminal",
    "development",
    "uptime"
  ],
  "chassis": "",
  "dev_tools": [
    {
      "icon": "󱘗",
      "name": "Rust",
      "cmd": "rustc --version 2>/dev/null | awk '{print $2}'"
    },
    {
      "icon": "󰙱",
      "name": "Clang",
      "cmd": "clang --version 2>/dev/null | grep -oP 'version [0-9.]+' | awk '{print $2}'"
    },
    {
      "icon": "󰎙",
      "name": "NodeJS",
      "cmd": "node --version 2>/dev/null"
    },
    {
      "icon": "󰟓",
      "name": "Go",
      "cmd": "go version 2>/dev/null | awk '{print $3}' | tr -d go"
    },
    {
      "icon": "󰪳",
      "name": ".NET",
      "cmd": "dotnet --version 2>/dev/null"
    },
    {
      "icon": "󰨞",
      "name": "Editor",
      "cmd": "code --version 2>/dev/null | head -1"
    },
    {
      "icon": "󰊢",
      "name": "Git",
      "cmd": "git --version 2>/dev/null | awk '{print $3}'"
    }
  ],
  "window": {
    "width": 700,
    "height_mini": 380,
    "height_full": 680
  },
  "gradient_bar": {
    "enabled": true,
    "color_a": "#ff6f91",
    "color_b": "#ff4081"
  },
  "layout": "left",
  "bg_image": {
    "path": "",
    "size": 300,
    "opacity": 0.75,
    "enabled": true
  },
  "animation": {
    "enabled": true,
    "type": "rain",
    "scope": "full",
    "color": "#ff6f91",
    "opacity": 0.45,
    "speed": 5,
    "drops": 90
  }
}
