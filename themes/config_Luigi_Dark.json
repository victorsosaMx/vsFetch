{
  "palette": {
    "bg": "#0e1412",
    "bg_header": "#151d19",
    "border": "#26332c",
    "text": "#d7efe1",
    "text_dim": "#6f8f7f",
    "text_mid": "#9fc5b0",
    "accent": "#4caf50",
    "ok": "#81c784",
    "mid": "#aed581",
    "hi": "#00e676",
    "btn_github": "#2e7d32",
    "btn_github_hover": "#388e3c",
    "btn_web": "#1b5e20",
    "btn_web_hover": "#2e7d32"
  },
  "font": "JetBrainsMono Nerd Font",
  "font_sizes": {
    "title": 20,
    "body": 13,
    "small": 11
  },
  "logo": {
    "size": 56,
    "override": "",
    "sidebar_position": "bottom"
  },
  "default_mode": "body",
  "sections": [
    "hardware",
    "desktop",
    "terminal",
    "development",
    "uptime"
  ],
  "chassis": "",
  "dev_tools": [
    {
      "icon": "󱘗",
      "name": "Rust",
      "cmd": "rustc --version 2>/dev/null | awk '{print $2}'"
    },
    {
      "icon": "󰙱",
      "name": "Clang",
      "cmd": "clang --version 2>/dev/null | grep -oP 'version [0-9.]+' | awk '{print $2}'"
    },
    {
      "icon": "󰎙",
      "name": "NodeJS",
      "cmd": "node --version 2>/dev/null"
    },
    {
      "icon": "󰟓",
      "name": "Go",
      "cmd": "go version 2>/dev/null | awk '{print $3}' | tr -d go"
    },
    {
      "icon": "󰪳",
      "name": ".NET",
      "cmd": "dotnet --version 2>/dev/null"
    },
    {
      "icon": "󰨞",
      "name": "Editor",
      "cmd": "code --version 2>/dev/null | head -1"
    },
    {
      "icon": "󰊢",
      "name": "Git",
      "cmd": "git --version 2>/dev/null | awk '{print $3}'"
    }
  ],
  "window": {
    "width": 700,
    "height_mini": 380,
    "height_full": 680
  },
  "gradient_bar": {
    "enabled": true,
    "color_a": "#4caf50",
    "color_b": "#000000"
  },
  "layout": "left",
  "bg_image": {
    "path": "",
    "size": 300,
    "opacity": 0.75,
    "enabled": true
  },
  "animation": {
    "enabled": true,
    "type": "matrix",
    "scope": "body",
    "color": "#4caf50",
    "opacity": 0.28,
    "speed": 1.0,
    "drops": 60
  }
}
