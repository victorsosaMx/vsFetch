def load_config():
    cfg = json.loads(json.dumps(DEFAULTS))   # deep copy
    if os.path.exists(CONFIG_PATH):
        try:
            with open(CONFIG_PATH) as f:
                user = json.load(f)
            # merge each sub-section
            for section in ("palette", "window"):
                if section in user:
                    cfg[section].update(user[section])
            if "font" in user:
                cfg["font"] = user["font"]
            if "default_mode" in user:
                cfg["default_mode"] = user["default_mode"]
            if "font_sizes" in user:
                cfg["font_sizes"].update(user["font_sizes"])
            if "logo" in user:
                cfg["logo"].update(user["logo"])
            if "sections" in user:
                cfg["sections"] = user["sections"]
            if "chassis" in user:
                cfg["chassis"] = user["chassis"]
            if "dev_tools" in user:
                cfg["dev_tools"] = user["dev_tools"]
        except Exception as e:
            print(f"vsFetch: could not read config ({e}), using defaults", file=sys.stderr)
    return cfg

