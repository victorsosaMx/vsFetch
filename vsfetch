def uptime_info():
    upt   = run("uptime -p | sed 's/up //'")
    user    = os.environ.get("USER") or os.environ.get("LOGNAME") or run("whoami 2>/dev/null")
    tty_raw = run("tty 2>/dev/null")
    tty     = tty_raw.replace("/dev/", "", 1) if tty_raw and tty_raw not in ("N/A", "") and "not a tty" not in tty_raw else "localhost"
    login   = f"{user}@{tty}"
    os_age = "N/A"
    for log_cmd in [
        "head -1 /var/log/pacman.log 2>/dev/null | grep -oP '[0-9]{4}-[0-9]{2}-[0-9]{2}'",
        "head -1 /var/log/dpkg.log 2>/dev/null | grep -oP '[0-9]{4}-[0-9]{2}-[0-9]{2}'",
        "head -1 /var/log/dnf.rpm.log 2>/dev/null | grep -oP '[0-9]{4}-[0-9]{2}-[0-9]{2}'",
        "head -1 /var/log/zypp/history 2>/dev/null | grep -oP '[0-9]{4}-[0-9]{2}-[0-9]{2}'",
        "head -1 /var/log/yum.log 2>/dev/null | grep -oP '[0-9]{4}-[0-9]{2}-[0-9]{2}'",
    ]:
        age_dt = run(log_cmd)
        if age_dt and age_dt != "N/A" and len(age_dt) == 10:
            days = run(f"echo $(( ( $(date +%s) - $(date -d {age_dt} +%s 2>/dev/null || echo $(date +%s)) ) / 86400 ))")
            os_age = f"{age_dt} [{days} days]"
            break
    return [
        ("󰔟", "Uptime", upt),
        ("󰀄", "Login",  login),
        ("󰃰", "OS Age", os_age),
    ]

