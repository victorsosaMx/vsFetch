def _merge_config(cfg, user):
    for section in ("palette", "font_sizes", "logo", "window", "gradient_bar", "bg_image", "animation"):
        if section in user:
            cfg[section].update(user[section])
    for key in ("font", "default_mode", "sections", "chassis", "dev_tools", "layout"):
        if key in user:
            cfg[key] = user[key]

def load_config():
    cfg = json.loads(json.dumps(DEFAULTS))   # deep copy
    if os.path.exists(CONFIG_PATH):
        try:
            with open(CONFIG_PATH) as f:
                user = json.load(f)
            _merge_config(cfg, user)
            if _CLI_CONFIG is None and "extends" in user:
                ext_path = os.path.expanduser(user["extends"])
                if os.path.isfile(ext_path):
                    try:
                        with open(ext_path) as f2:
                            _merge_config(cfg, json.load(f2))
                    except Exception as e:
                        print(f"vsFetch: could not read extends config ({e})", file=sys.stderr)
                else:
                    print(f"vsFetch: extends file not found: {ext_path}", file=sys.stderr)
        except Exception as e:
            print(f"vsFetch: could not read config ({e}), using defaults", file=sys.stderr)
    return cfg

