def sys_info():
    return [
        ("󰌽", "Linux",   run("uname -o") + " " + run("uname -m")),
        ("󰥔", "Fetched", run("date '+%Y-%m-%d %H:%M:%S %Z'")),
        ("󰀲", "Locale",  os.environ.get("LANG", run("locale | grep LANG= | cut -d= -f2"))),
    ]

def hardware_info():
    rows = []
    _chassis_map = {
        "1": "Other",      "2": "Unknown",    "3": "Desktop",
        "4": "Desktop",    "5": "Desktop",    "6": "Tower",
        "7": "Tower",      "8": "Portable",   "9": "Laptop",
        "10": "Notebook",  "11": "Handheld",  "13": "All-in-One",
        "14": "Notebook",  "17": "Server",    "23": "Server",
        "28": "Blade",     "30": "Tablet",    "31": "Convertible",
        "32": "Detachable","35": "Mini PC",   "36": "Stick PC",
    }
    if CFG["chassis"]:
        chassis = CFG["chassis"]
    else:
        try:
            with open("/sys/class/dmi/id/chassis_type") as _f:
                _ct = _f.read().strip()
            chassis = _chassis_map.get(_ct, f"Unknown ({_ct})")
        except Exception:
            chassis = "Unknown"
    rows.append(("󰍹", "Chassis", chassis))

    ram_total = run("free -h | awk '/^Mem:/{print $2}'")
    ram_used  = run("free -h | awk '/^Mem:/{print $3}'")
    ram_pct   = run("free | awk '/^Mem:/{printf \"%d%%\", $3/$2*100}'")
    rows.append(("󰓅", "RAM", f"{ram_used} / {ram_total}", ram_pct))

    swap = run("free -h | awk '/^Swap:/{print $2}'")
    if swap in ("0B", "0", ""):
        rows.append(("󰁡", "SWAP", "Disabled"))
    else:
        swap_used = run("free -h | awk '/^Swap:/{print $3}'")
        rows.append(("󰁡", "SWAP", f"{swap_used} / {swap}"))

    cpu = run("grep 'model name' /proc/cpuinfo | head -1 | cut -d: -f2").strip()
    cores = run("nproc")
    freq  = run("grep 'cpu MHz' /proc/cpuinfo | awk '{s+=$4;n++} END{printf \"%.2f GHz\", s/n/1000}'")
    rows.append(("󰍛", "CPU", f"{cpu} ({cores}) @ {freq}"))

    gpu = run("lspci | grep -i 'VGA compatible controller' | head -1 | sed 's/.*: //;s/ (rev.*//' | sed 's/Advanced Micro Devices, Inc. \\[AMD.ATI\\] //'")
    rows.append(("󰍹", "GPU", f"{gpu} [Discrete]"))

    disks = run("df -h --output=source,size,used,pcent,target -x tmpfs -x devtmpfs -x efivarfs | tail -n +2")
    for line in disks.splitlines():
        p = line.split()
        if len(p) >= 5 and p[0].startswith('/dev/'):
            fs = run(f"lsblk -no FSTYPE {p[0]} 2>/dev/null | head -1") or ""
            rows.append(("󰋊", "Disk", f"{p[2]} / {p[1]}", p[3], f"— {fs}"))
    return rows

def desktop_info():
    session = os.environ.get('XDG_SESSION_TYPE', 'wayland')
    ver = run("hyprctl version 2>/dev/null | grep -oP 'v[0-9]+\\.[0-9]+\\.[0-9]+' | head -1")
    label = f"Hyprland {ver} ({session.capitalize()})" if ver else os.environ.get('XDG_CURRENT_DESKTOP','')

    # Active monitors only via JSON
    try:
        raw = subprocess.check_output("hyprctl monitors -j", shell=True, stderr=subprocess.DEVNULL).decode()
        monitors = json.loads(raw)
        displays = "  ".join(f"{m['name']}: {m['width']}x{m['height']}@{round(m['refreshRate'])}Hz" for m in monitors)
    except Exception:
        displays = "N/A"

    driver = run("lsmod | awk '/^amdgpu/{print \"amdgpu\"}' | head -1") or \
             run("lsmod | awk '/^nvidia/{print \"nvidia\"}' | head -1") or "N/A"
    return [
        ("󰉼", "Session",  label),
        ("󰍹", "Display",  displays),
        ("󰍹", "G-Driver", driver),
    ]

def terminal_info():
    shell = run("fish --version 2>/dev/null || $SHELL --version 2>/dev/null | head -1")
    term  = run("kitty --version 2>/dev/null | head -1 | awk '{print $1\" \"$2}' || echo $TERM")
    font  = run("grep -E '^font_family' ~/.config/kitty/kitty.conf 2>/dev/null | awk '{$1=\"\"; print $0}' | xargs") or "JetBrainsMono NF"
    theme = run("gsettings get org.gnome.desktop.interface color-scheme 2>/dev/null | tr -d \"'\" || echo 'Dark'")
    pac   = run("pacman -Q 2>/dev/null | wc -l")
    flat  = run("flatpak list 2>/dev/null | wc -l")
    return [
        ("󰈺", "Shell",     shell),
        ("󰆍", "Terminal",  term),
        ("󰛖", "Term Font", font.strip()),
        ("󰏘", "Packages",  f"{pac} (pacman), {flat} (flatpak)"),
    ]

def dev_info():
    results = []
    for t in CFG["dev_tools"]:
        v = run(t["cmd"])
        if v and v not in ("N/A", ""):
            results.append((t["icon"], t["name"], v))
    return results

def uptime_info():
    upt   = run("uptime -p | sed 's/up //'")
    login = run("who am i 2>/dev/null | awk '{print $1\"@\"$2, $3, $4}' | head -1") or \
            run("echo $USER@$(tty | tr -d /dev/)")
    age_ts = run("stat -c %Y /var/log/pacman.log 2>/dev/null | head -1")
    if age_ts and age_ts != "N/A":
        days   = run(f"echo $(( ( $(date +%s) - $(head -1 /var/log/pacman.log | grep -oP '[0-9]{{4}}-[0-9]{{2}}-[0-9]{{2}}' | xargs -I{{}} date -d {{}} +%s 2>/dev/null || echo $(date +%s)) ) / 86400 ))")
        age_dt = run("head -1 /var/log/pacman.log | grep -oP '[0-9]{4}-[0-9]{2}-[0-9]{2}'")
        os_age = f"{age_dt} [{days} days]"
    else:
        os_age = "N/A"
    return [
        ("󰔟", "Uptime", upt),
        ("󰀄", "Login",  login),
        ("󰃰", "OS Age", os_age),
    ]

# ── window ────────────────────────────────────────────────────────────────────

class AboutSystem(Gtk.Window):
    def __init__(self):
        super().__init__(title="About This System")
        self.set_default_size(W["width"], W["height_mini"] if MINI else W["height_full"])
        self.set_resizable(False)
        self.set_position(Gtk.WindowPosition.CENTER)

        self.set_border_width(0)

        provider = Gtk.CssProvider()
        provider.load_from_data(CSS)
        Gtk.StyleContext.add_provider_for_screen(
            Gdk.Screen.get_default(), provider,
            Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION
        )

        root = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        self.add(root)

        # header ──────────────────────────────────────────────────
        header = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=18)
        header.get_style_context().add_class("header")
        header.set_margin_top(24); header.set_margin_bottom(24)
        header.set_margin_start(36); header.set_margin_end(36)
        root.pack_start(header, False, False, 0)

        # Cargar ícono: override (archivo/nombre) > auto-detección por OS
        logo_size    = CFG["logo"]["size"]
        logo_override = os.path.expanduser(CFG["logo"]["override"])
        icon_theme = Gtk.IconTheme.get_default()
        icon_theme.append_search_path("/usr/share/icons/Papirus")

        if logo_override and os.path.isfile(logo_override):
            # path a archivo de imagen
            logo_widget = Gtk.Image.new_from_pixbuf(
                GdkPixbuf.Pixbuf.new_from_file_at_size(logo_override, logo_size, logo_size)
            )
        elif logo_override and icon_theme.has_icon(logo_override):
            # nombre de icono del theme
            logo_widget = Gtk.Image.new_from_icon_name(logo_override, Gtk.IconSize.INVALID)
            logo_widget.set_pixel_size(logo_size)
        else:
            # auto-detección por OS
            os_id = run("grep '^ID=' /etc/os-release | cut -d= -f2 | tr -d '\"'").lower()
            icon_id_map = {"arch": "archlinux", "opensuse-leap": "opensuse", "opensuse-tumbleweed": "opensuse"}
            icon_id   = icon_id_map.get(os_id, os_id)
            icon_name = f"distributor-logo-{icon_id}"
            name      = icon_name if icon_theme.has_icon(icon_name) else "preferences-system"
            logo_widget = Gtk.Image.new_from_icon_name(name, Gtk.IconSize.INVALID)
            logo_widget.set_pixel_size(logo_size)
        logo_widget.set_margin_top(5); logo_widget.set_margin_bottom(5)
        logo_widget.set_margin_start(5); logo_widget.set_margin_end(5)
        header.pack_start(logo_widget, False, False, 0)

        hbox = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=3)
        hbox.set_valign(Gtk.Align.CENTER)
        hbox.set_margin_start(15)
        header.pack_start(hbox, True, True, 0)

        os_name = run("grep '^PRETTY_NAME=' /etc/os-release | cut -d= -f2 | tr -d '\"'")
        t = Gtk.Label(label=f"{os_name}  ·  vsFetch 1.1")
        t.get_style_context().add_class("distro")
        t.set_halign(Gtk.Align.START)
        hbox.pack_start(t, False, False, 0)

        s = Gtk.Label(label=run("date '+%Y-%m-%d  %H:%M:%S  %Z'") + "  ·  " + os.environ.get("LANG",""))
        s.get_style_context().add_class("fetched")
        s.set_halign(Gtk.Align.START)
        hbox.pack_start(s, False, False, 0)

        root.pack_start(Gtk.Separator(orientation=Gtk.Orientation.HORIZONTAL), False, False, 0)

        # body ────────────────────────────────────────────────────
        outer = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        outer.set_margin_top(12); outer.set_margin_bottom(20)
        root.pack_start(outer, True, True, 0)

        # inner container de ancho fijo, centrado
        body = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        body.set_size_request(580, -1)
        body.set_halign(Gtk.Align.CENTER)
        outer.pack_start(body, True, True, 0)

        def add_section(title, rows):
            lbl = Gtk.Label(label=f"── {title} ──")
            lbl.get_style_context().add_class("section")
            lbl.set_halign(Gtk.Align.CENTER)
            lbl.set_margin_top(16); lbl.set_margin_bottom(6)
            body.pack_start(lbl, False, False, 0)

            grid = Gtk.Grid()
            grid.set_row_spacing(6)
            grid.set_column_spacing(16)
            grid.set_halign(Gtk.Align.START)
            body.pack_start(grid, False, False, 0)

            for i, row in enumerate(rows):
                # row = (icon, key, value)  or  (icon, key, value, pct_str, extra)
                icon, key, value = row[0], row[1], row[2]
                pct   = row[3] if len(row) > 3 else None
                extra = row[4] if len(row) > 4 else None

                ic_lbl = Gtk.Label(label=icon + " ")
                ic_lbl.get_style_context().add_class("icon")
                ic_lbl.set_halign(Gtk.Align.END)
                grid.attach(ic_lbl, 0, i, 1, 1)

                k_lbl = Gtk.Label(label=key)
                k_lbl.get_style_context().add_class("key")
                k_lbl.set_halign(Gtk.Align.START)
                k_lbl.set_size_request(90, -1)
                grid.attach(k_lbl, 1, i, 1, 1)

                val_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=6)
                grid.attach(val_box, 2, i, 1, 1)

                v_lbl = Gtk.Label(label=value)
                v_lbl.get_style_context().add_class("val")
                v_lbl.set_halign(Gtk.Align.START)
                v_lbl.set_selectable(True)
                val_box.pack_start(v_lbl, False, False, 0)

                if pct:
                    p_lbl = Gtk.Label(label=f"({pct})")
                    p_lbl.get_style_context().add_class(pct_class(pct))
                    val_box.pack_start(p_lbl, False, False, 0)

                if extra:
                    e_lbl = Gtk.Label(label=extra)
                    e_lbl.get_style_context().add_class("fetched")
                    e_lbl.set_halign(Gtk.Align.START)
                    val_box.pack_start(e_lbl, False, False, 0)

        _section_map = {
            "hardware":    ("Hardware",    hardware_info),
            "desktop":     ("Desktop",     desktop_info),
            "terminal":    ("Terminal",    terminal_info),
            "development": ("Development", dev_info),
            "uptime":      ("Uptime",      uptime_info),
        }

        if MINI:
            add_section("Hardware", hardware_info())
        else:
            for key in CFG["sections"]:
                if key in _section_map:
                    title, fn = _section_map[key]
                    add_section(title, fn())

        self.connect("destroy", Gtk.main_quit)


