class AboutSystem(Gtk.Window):
    def __init__(self):
        super().__init__(title="About This System")
        self.set_resizable(False)
        self.set_position(Gtk.WindowPosition.CENTER)

        self.set_border_width(0)

        provider = Gtk.CssProvider()
        provider.load_from_data(CSS)
        display = Gdk.Display.get_default()
        screen = display.get_default_screen() if display else Gdk.Screen.get_default()
        Gtk.StyleContext.add_provider_for_screen(
            screen, provider,
            Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION
        )

        layout = CFG.get("layout", "top")
        root = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL if layout == "left" else Gtk.Orientation.VERTICAL)

        overlay      = Gtk.Overlay()
        body_overlay = Gtk.Overlay()
        overlay.add(root)
        self.add(overlay)

        # ── collect section data and auto-size window ─────────────
        _section_map = {
            "hardware":    ("Hardware",    hardware_info),
            "desktop":     ("Desktop",     desktop_info),
            "terminal":    ("Terminal",    terminal_info),
            "development": ("Development", dev_info),
            "uptime":      ("Uptime",      uptime_info),
        }

        if MINI:
            sections_data = [("Hardware", hardware_info())]
        else:
            sections_data = []
            for key in CFG["sections"]:
                if key in _section_map:
                    title, fn = _section_map[key]
                    sections_data.append((title, fn()))

        total_rows = sum(len(rows) for _, rows in sections_data)
        num_sections = len(sections_data)
        header_h = 32 if CFG.get("layout", "top") == "left" else 115
        row_h = 18
        section_h = 20
        padding = 20
        auto_h = header_h + num_sections * section_h + total_rows * row_h + padding
        cfg_h = W["height_mini"] if MINI else W["height_full"]
        display = Gdk.Display.get_default()
        monitor = display.get_primary_monitor() if display else None
        if not monitor and display:
            monitor = display.get_monitor(0)
        max_h = int(monitor.get_geometry().height * 0.9) if monitor else None
        final_h = min(max(cfg_h, auto_h), max_h) if max_h else max(cfg_h, auto_h)
        self.set_default_size(W["width"], final_h)
        if MINI:
            W["height_mini"] = final_h
        else:
            W["height_full"] = final_h

        # ── animation ─────────────────────────────────────────────
        AN = CFG["animation"]

        def _add_anim(canvas, draw_fn, tick_fn):
            canvas.set_halign(Gtk.Align.FILL)
            canvas.set_valign(Gtk.Align.FILL)
            canvas.set_opacity(float(AN["opacity"]))
            canvas.connect("draw", draw_fn)
            GLib.timeout_add(16, tick_fn)
            target = overlay if AN.get("scope", "body") == "full" else body_overlay
            target.add_overlay(canvas)
            target.set_overlay_pass_through(canvas, True)

        if AN["enabled"] and AN["type"] == "rain":
            rain_color = hex_to_rgb(AN["color"]) if AN["color"] else hex_to_rgb(P["accent"])
            speed_mult = float(AN["speed"])
            win_w      = W["width"]
            win_h      = W["height_mini"] if MINI else W["height_full"]
            ANGLE      = math.radians(15)
            SIN_A      = math.sin(ANGLE)
            COS_A      = math.cos(ANGLE)
            TAN_A      = math.tan(ANGLE)

            drops = [
                {
                    "x":      random.uniform(0, win_w),
                    "y":      random.uniform(-150, 0),
                    "length": random.randint(10, 45),
                    "speed":  random.uniform(4, 10) * speed_mult,
                    "alpha":  random.uniform(0.3, 1.0),
                }
                for _ in range(int(AN["drops"]))
            ]

            rain_canvas = Gtk.DrawingArea()

            def draw_rain(widget, cr):
                cr.set_line_width(1.2)
                for d in drops:
                    cr.set_source_rgba(*rain_color, d["alpha"])
                    cr.move_to(d["x"], d["y"])
                    cr.line_to(d["x"] - d["length"] * SIN_A, d["y"] - d["length"] * COS_A)
                    cr.stroke()

            def tick_rain():
                for d in drops:
                    d["y"] += d["speed"]
                    d["x"] += d["speed"] * TAN_A
                    if d["y"] - d["length"] > win_h or d["x"] > win_w:
                        d["y"] = random.uniform(-d["length"] * 2, 0)
                        d["x"] = random.uniform(-50, win_w)
                        d["alpha"] = random.uniform(0.3, 1.0)
                        d["speed"] = random.uniform(4, 10) * speed_mult
                rain_canvas.queue_draw()
                return True

            _add_anim(rain_canvas, draw_rain, tick_rain)

        elif AN["enabled"] and AN["type"] == "snow":
            snow_color = hex_to_rgb(AN["color"]) if AN["color"] else (1.0, 1.0, 1.0)
            speed_mult = float(AN["speed"])
            win_w      = W["width"]
            win_h      = W["height_mini"] if MINI else W["height_full"]

            flakes = [
                {
                    "x":     random.uniform(0, win_w),
                    "y":     random.uniform(-win_h, 0),
                    "r":     random.uniform(1.5, 3.5),
                    "speed": random.uniform(0.6, 2.0) * speed_mult,
                    "drift": random.uniform(0.3, 1.2),
                    "freq":  random.uniform(0.01, 0.03),
                    "phase": random.uniform(0, 2 * math.pi),
                    "alpha": random.uniform(0.4, 1.0),
                    "t":     random.uniform(0, 1000),
                }
                for _ in range(int(AN["drops"]))
            ]

            snow_canvas = Gtk.DrawingArea()

            def draw_snow(widget, cr):
                for f in flakes:
                    cr.set_source_rgba(*snow_color, f["alpha"])
                    cr.arc(f["x"], f["y"], f["r"], 0, 2 * math.pi)
                    cr.fill()

            def tick_snow():
                for f in flakes:
                    f["t"] += 1
                    f["y"] += f["speed"]
                    f["x"] += math.sin(f["t"] * f["freq"] + f["phase"]) * f["drift"]
                    if f["y"] - f["r"] > win_h:
                        f["y"] = random.uniform(-f["r"] * 2, 0)
                        f["x"] = random.uniform(0, win_w)
                        f["alpha"] = random.uniform(0.4, 1.0)
                        f["speed"] = random.uniform(0.6, 2.0) * speed_mult
                        f["t"]     = random.uniform(0, 1000)
                snow_canvas.queue_draw()
                return True

            _add_anim(snow_canvas, draw_snow, tick_snow)

        elif AN["enabled"] and AN["type"] == "matrix":
            mat_color  = hex_to_rgb(AN["color"]) if AN["color"] else hex_to_rgb(P["accent"])
            speed_mult = float(AN["speed"])
            win_w      = W["width"]
            win_h      = W["height_mini"] if MINI else W["height_full"]
            CHAR_SIZE  = 14
            CHARS      = "ｦｧｨｩｪｫｬｭｮｯｰｱｲｳｴｵｶｷｸｹｺｻｼｽｾｿﾀﾁﾂﾃﾄﾅﾆﾇﾈﾉﾊﾋﾌﾍﾎﾏﾐﾑﾒﾓﾔﾕﾖﾗﾘﾙﾚﾛﾜﾝ0123456789"

            num_cols = win_w // CHAR_SIZE
            columns  = [
                {
                    "x":     i * CHAR_SIZE,
                    "y":     random.uniform(-win_h, 0),
                    "speed": random.uniform(2, 7) * speed_mult,
                    "trail": random.randint(8, 22),
                    "chars": [random.choice(CHARS) for _ in range(25)],
                }
                for i in range(num_cols)
            ]

            mat_canvas = Gtk.DrawingArea()

            def draw_matrix(widget, cr):
                cr.select_font_face("monospace", cairo.FONT_SLANT_NORMAL, cairo.FONT_WEIGHT_NORMAL)
                cr.set_font_size(CHAR_SIZE)
                for col in columns:
                    for i in range(col["trail"]):
                        cy = col["y"] - i * CHAR_SIZE
                        if cy < 0 or cy > win_h:
                            continue
                        if i == 0:
                            cr.set_source_rgba(1.0, 1.0, 1.0, 1.0)
                        else:
                            alpha = (1.0 - i / col["trail"]) ** 1.5
                            cr.set_source_rgba(*mat_color, alpha)
                        cr.move_to(col["x"], cy)
                        cr.show_text(col["chars"][i % len(col["chars"])])

            def tick_matrix():
                for col in columns:
                    col["y"] += col["speed"]
                    if random.random() < 0.15:
                        col["chars"][random.randint(0, len(col["chars"]) - 1)] = random.choice(CHARS)
                    if col["y"] - col["trail"] * CHAR_SIZE > win_h:
                        col["y"]     = random.uniform(-col["trail"] * CHAR_SIZE, 0)
                        col["speed"] = random.uniform(2, 7) * speed_mult
                        col["trail"] = random.randint(8, 22)
                mat_canvas.queue_draw()
                return True

            _add_anim(mat_canvas, draw_matrix, tick_matrix)

        elif AN["enabled"] and AN["type"] == "aurora":
            speed_mult = float(AN["speed"])
            win_h      = W["height_mini"] if MINI else W["height_full"]

            bands = [
                {"y_frac": 0.50, "amp": 50, "freq": 0.007, "phase": 0.0, "spd": 0.012 * speed_mult, "color": hex_to_rgb(AN["color"]) if AN["color"] else hex_to_rgb(P["accent"]), "alpha": 0.55},
                {"y_frac": 0.63, "amp": 60, "freq": 0.005, "phase": 2.1, "spd": 0.009 * speed_mult, "color": hex_to_rgb(P["hi"]),                                                   "alpha": 0.45},
                {"y_frac": 0.76, "amp": 45, "freq": 0.009, "phase": 4.2, "spd": 0.015 * speed_mult, "color": hex_to_rgb(P["ok"]),                                                   "alpha": 0.40},
            ]

            aurora_canvas = Gtk.DrawingArea()

            def draw_aurora(widget, cr):
                w = widget.get_allocated_width()
                h = widget.get_allocated_height()
                for band in bands:
                    y_base    = band["y_frac"] * h
                    amp       = band["amp"]
                    r, g, b   = band["color"]
                    cr.move_to(0, h)
                    for x in range(0, w + 2, 2):
                        cr.line_to(x, y_base + amp * math.sin(x * band["freq"] + band["phase"]))
                    cr.line_to(w, h)
                    cr.close_path()
                    grad = cairo.LinearGradient(0, y_base - amp * 2, 0, y_base + amp * 2)
                    grad.add_color_stop_rgba(0.0, r, g, b, 0.0)
                    grad.add_color_stop_rgba(0.4, r, g, b, band["alpha"])
                    grad.add_color_stop_rgba(1.0, r, g, b, 0.0)
                    cr.set_source(grad)
                    cr.fill()

            def tick_aurora():
                for band in bands:
                    band["phase"] += band["spd"]
                aurora_canvas.queue_draw()
                return True

            _add_anim(aurora_canvas, draw_aurora, tick_aurora)

        elif AN["enabled"] and AN["type"] == "warp":
            warp_color = hex_to_rgb(AN["color"]) if AN["color"] else (1.0, 1.0, 1.0)
            speed_mult = float(AN["speed"])
            win_w      = W["width"]
            win_h      = W["height_mini"] if MINI else W["height_full"]
            cx         = win_w / 2
            cy         = win_h / 2
            max_dist   = math.sqrt(cx**2 + cy**2) * 1.2

            stars = [
                {
                    "angle": random.uniform(0, 2 * math.pi),
                    "dist":  random.uniform(0, max_dist),
                    "speed": random.uniform(1.0, 3.0) * speed_mult,
                    "alpha": random.uniform(0.4, 1.0),
                }
                for _ in range(int(AN["drops"]))
            ]

            warp_canvas = Gtk.DrawingArea()

            def draw_warp(widget, cr):
                r, g, b = warp_color
                for s in stars:
                    dist = s["dist"]
                    if dist < 1:
                        continue
                    trail  = max(2, dist * 0.15)
                    x1     = cx + math.cos(s["angle"]) * dist
                    y1     = cy + math.sin(s["angle"]) * dist
                    x0     = cx + math.cos(s["angle"]) * (dist - trail)
                    y0     = cy + math.sin(s["angle"]) * (dist - trail)
                    alpha  = s["alpha"] * min(1.0, dist / (max_dist * 0.3))
                    cr.set_line_width(0.5 + (dist / max_dist) * 1.5)
                    cr.set_source_rgba(r, g, b, alpha)
                    cr.move_to(x0, y0)
                    cr.line_to(x1, y1)
                    cr.stroke()

            def tick_warp():
                for s in stars:
                    s["dist"] += s["speed"] * (1.0 + s["dist"] / (max_dist * 0.4))
                    if s["dist"] > max_dist:
                        s["dist"]  = random.uniform(0, 5)
                        s["angle"] = random.uniform(0, 2 * math.pi)
                        s["alpha"] = random.uniform(0.4, 1.0)
                        s["speed"] = random.uniform(1.0, 3.0) * speed_mult
                warp_canvas.queue_draw()
                return True

            _add_anim(warp_canvas, draw_warp, tick_warp)

        os_id         = run("grep '^ID=' /etc/os-release | cut -d= -f2 | tr -d '\"'").lower()
        os_name       = run("grep '^PRETTY_NAME=' /etc/os-release | cut -d= -f2 | tr -d '\"'")
        _it           = _icon_theme()
        _date         = run("date '+%Y-%m-%d  %H:%M:%S  %Z'")
        date_str      = _date + "  ·  " + os.environ.get("LANG", "")
        date_str_slim = _date

        BI = CFG["bg_image"]
        bi_path = os.path.expanduser(BI["path"])
        try:
            if not BI.get("enabled", False): raise ValueError("bg_image disabled")
            sz = int(BI["size"])
            if bi_path and os.path.isfile(bi_path):
                pb = GdkPixbuf.Pixbuf.new_from_file_at_scale(bi_path, sz, sz, True)
            else:
                pb = _it.load_icon(_distro_icon_name(_it, os_id), sz, Gtk.IconLookupFlags.FORCE_SIZE)
            bi_img = Gtk.Image.new_from_pixbuf(pb)
            bi_img.set_halign(Gtk.Align.END)
            bi_img.set_valign(Gtk.Align.END)
            bi_img.set_opacity(float(BI["opacity"]))
            overlay.add_overlay(bi_img)
            overlay.set_overlay_pass_through(bi_img, True)
        except Exception:
            pass

        # ── logo (shared) ─────────────────────────────────────────
        logo_size     = CFG["logo"]["size"]
        logo_override = os.path.expanduser(CFG["logo"]["override"])

        if logo_override and os.path.isfile(logo_override):
            logo_widget = Gtk.Image.new_from_pixbuf(
                GdkPixbuf.Pixbuf.new_from_file_at_size(logo_override, logo_size, logo_size)
            )
        elif logo_override and _it.has_icon(logo_override):
            logo_widget = Gtk.Image.new_from_icon_name(logo_override, Gtk.IconSize.INVALID)
            logo_widget.set_pixel_size(logo_size)
        else:
            logo_widget = Gtk.Image.new_from_icon_name(_distro_icon_name(_it, os_id), Gtk.IconSize.INVALID)
            logo_widget.set_pixel_size(logo_size)
        GB       = CFG["gradient_bar"]

        def make_grad_bar(vertical=False):
            offset = [0.0]
            bar = Gtk.DrawingArea()
            bar.set_size_request(3 if vertical else -1, -1 if vertical else 3)

            def draw(widget, cr):
                dim = widget.get_allocated_height() if vertical else widget.get_allocated_width()
                o   = offset[0] % dim
                grad = cairo.LinearGradient(0, o - dim, 0, o + dim) if vertical \
                       else cairo.LinearGradient(o - dim, 0, o + dim, 0)
                grad.add_color_stop_rgb(0.0, *hex_to_rgb(GB["color_a"]))
                grad.add_color_stop_rgb(0.5, *hex_to_rgb(GB["color_b"]))
                grad.add_color_stop_rgb(1.0, *hex_to_rgb(GB["color_a"]))
                cr.set_source(grad)
                cr.paint()

            def tick():
                offset[0] += 2.5
                bar.queue_draw()
                return True

            bar.connect("draw", draw)
            GLib.timeout_add(16, tick)
            return bar

        if layout == "left":
            # ── sidebar ───────────────────────────────────────────
            sidebar = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
            sidebar.get_style_context().add_class("header")
            sidebar.set_size_request(90, -1)
            root.pack_start(sidebar, False, False, 0)

            icon_pos = CFG["logo"].get("sidebar_position", "bottom")

            logo_widget.set_margin_start(5); logo_widget.set_margin_end(5)
            if icon_pos == "top":
                logo_widget.set_margin_top(20)
                sidebar.pack_start(logo_widget, False, False, 0)

            text_area = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=24)
            text_area.set_valign(Gtk.Align.CENTER)
            text_area.set_margin_top(24); text_area.set_margin_bottom(24)
            sidebar.pack_start(text_area, True, True, 0)

            t = Gtk.Label(label=f"{os_name}  ·  {_APP_VER}")
            t.get_style_context().add_class("distro")
            t.set_angle(90)
            text_area.pack_start(t, False, False, 0)

            s = Gtk.Label(label=date_str_slim)
            s.get_style_context().add_class("fetched")
            s.set_angle(90)
            text_area.pack_start(s, False, False, 0)

            if icon_pos != "top":
                logo_widget.set_margin_bottom(20)
                sidebar.pack_end(logo_widget, False, False, 0)

            if GB["enabled"]:
                root.pack_start(make_grad_bar(vertical=True), False, False, 0)
            else:
                root.pack_start(Gtk.Separator(orientation=Gtk.Orientation.VERTICAL), False, False, 0)

        else:
            # ── top header ────────────────────────────────────────
            header = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=18)
            header.get_style_context().add_class("header")
            header.set_margin_top(24); header.set_margin_bottom(24)
            header.set_margin_start(36); header.set_margin_end(36)
            root.pack_start(header, False, False, 0)

            logo_widget.set_margin_top(5); logo_widget.set_margin_bottom(5)
            logo_widget.set_margin_start(5); logo_widget.set_margin_end(5)
            header.pack_start(logo_widget, False, False, 0)

            hbox = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=3)
            hbox.set_valign(Gtk.Align.CENTER)
            hbox.set_margin_start(15)
            header.pack_start(hbox, True, True, 0)

            t = Gtk.Label(label=f"{os_name}  ·  {_APP_VER}")
            t.get_style_context().add_class("distro")
            t.set_halign(Gtk.Align.START)
            hbox.pack_start(t, False, False, 0)

            s = Gtk.Label(label=date_str)
            s.get_style_context().add_class("fetched")
            s.set_halign(Gtk.Align.START)
            hbox.pack_start(s, False, False, 0)

            if GB["enabled"]:
                root.pack_start(make_grad_bar(vertical=False), False, False, 0)
            else:
                root.pack_start(Gtk.Separator(orientation=Gtk.Orientation.HORIZONTAL), False, False, 0)

        # body ────────────────────────────────────────────────────
        outer = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        outer.set_margin_top(12); outer.set_margin_bottom(20)
        body_overlay.add(outer)
        root.pack_start(body_overlay, True, True, 0)

        # inner container de ancho fijo, centrado
        body = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        body.set_size_request(580, -1)
        body.set_halign(Gtk.Align.CENTER)
        outer.pack_start(body, True, True, 0)

        def add_section(title, rows):
            lbl = Gtk.Label(label=f"── {title} ──")
            lbl.get_style_context().add_class("section")
            lbl.set_halign(Gtk.Align.CENTER)
            lbl.set_margin_top(16); lbl.set_margin_bottom(6)
            body.pack_start(lbl, False, False, 0)

            grid = Gtk.Grid()
            grid.set_row_spacing(6)
            grid.set_column_spacing(16)
            grid.set_halign(Gtk.Align.START)
            body.pack_start(grid, False, False, 0)

            for i, row in enumerate(rows):
                # row = (icon, key, value)  or  (icon, key, value, pct_str, extra)
                icon, key, value = row[0], row[1], row[2]
                pct   = row[3] if len(row) > 3 else None
                extra = row[4] if len(row) > 4 else None

                ic_lbl = Gtk.Label(label=icon + " ")
                ic_lbl.get_style_context().add_class("icon")
                ic_lbl.set_halign(Gtk.Align.END)
                grid.attach(ic_lbl, 0, i, 1, 1)

                k_lbl = Gtk.Label(label=key)
                k_lbl.get_style_context().add_class("key")
                k_lbl.set_halign(Gtk.Align.START)
                k_lbl.set_size_request(90, -1)
                grid.attach(k_lbl, 1, i, 1, 1)

                val_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=6)
                grid.attach(val_box, 2, i, 1, 1)

                v_lbl = Gtk.Label(label=value)
                v_lbl.get_style_context().add_class("val")
                v_lbl.set_halign(Gtk.Align.START)
                v_lbl.set_selectable(True)
                v_lbl.set_can_focus(False)
                val_box.pack_start(v_lbl, False, False, 0)

                if pct:
                    p_lbl = Gtk.Label(label=f"({pct})")
                    p_lbl.get_style_context().add_class(pct_class(pct))
                    val_box.pack_start(p_lbl, False, False, 0)

                if extra:
                    e_lbl = Gtk.Label(label=extra)
                    e_lbl.get_style_context().add_class("fetched")
                    e_lbl.set_halign(Gtk.Align.START)
                    val_box.pack_start(e_lbl, False, False, 0)

        for title, rows in sections_data:
            add_section(title, rows)

        self.connect("destroy", Gtk.main_quit)


