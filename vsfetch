def hardware_info():
    rows = []
    _chassis_map = {
        "1": "Other",      "2": "Unknown",    "3": "Desktop",
        "4": "Desktop",    "5": "Desktop",    "6": "Tower",
        "7": "Tower",      "8": "Portable",   "9": "Laptop",
        "10": "Notebook",  "11": "Handheld",  "13": "All-in-One",
        "14": "Notebook",  "17": "Server",    "23": "Server",
        "28": "Blade",     "30": "Tablet",    "31": "Convertible",
        "32": "Detachable","35": "Mini PC",   "36": "Stick PC",
    }
    if CFG["chassis"]:
        chassis = CFG["chassis"]
    else:
        try:
            with open("/sys/class/dmi/id/chassis_type") as _f:
                _ct = _f.read().strip()
            chassis = _chassis_map.get(_ct, f"Unknown ({_ct})")
        except Exception:
            chassis = "Unknown"
    rows.append(("󰍹", "Chassis", chassis))

    ram_total = run("free -h | awk '/^Mem:/{print $2}'")
    ram_used  = run("free -h | awk '/^Mem:/{print $3}'")
    ram_pct   = run("free | awk '/^Mem:/{printf \"%d%%\", $3/$2*100}'")
    rows.append(("󰓅", "RAM", f"{ram_used} / {ram_total}", ram_pct))

    swap = run("free -h | awk '/^Swap:/{print $2}'")
    if swap in ("0B", "0", ""):
        rows.append(("󰁡", "SWAP", "Disabled"))
    else:
        swap_used = run("free -h | awk '/^Swap:/{print $3}'")
        rows.append(("󰁡", "SWAP", f"{swap_used} / {swap}"))

    cpu = run("grep 'model name' /proc/cpuinfo | head -1 | cut -d: -f2").strip()
    cores = run("nproc")
    freq  = run("grep 'cpu MHz' /proc/cpuinfo | awk '{s+=$4;n++} END{printf \"%.2f GHz\", s/n/1000}'")
    rows.append(("󰍛", "CPU", f"{cpu} ({cores}) @ {freq}"))

    gpu = run("lspci 2>/dev/null | grep -i 'VGA compatible controller' | head -1 | sed 's/.*: //;s/ (rev.*//' | sed 's/Advanced Micro Devices, Inc. \\[AMD.ATI\\] //'") or \
          run("lspci 2>/dev/null | grep -i '3D controller' | head -1 | sed 's/.*: //;s/ (rev.*//'")
    rows.append(("󰍹", "GPU", gpu or "N/A"))

    disks = run("df -h --output=source,size,used,pcent,target -x tmpfs -x devtmpfs -x efivarfs | tail -n +2")
    seen_devs = set()
    for line in disks.splitlines():
        p = line.split()
        if len(p) >= 5 and p[0].startswith('/dev/') and p[0] not in seen_devs:
            seen_devs.add(p[0])
            fs = run(f"lsblk -no FSTYPE {p[0]} 2>/dev/null | head -1") or ""
            rows.append(("󰋊", "Disk", f"{p[2]} / {p[1]}", p[3], f"— {fs}"))
    return rows

def desktop_info():
    session = os.environ.get('XDG_SESSION_TYPE', '')
    de      = os.environ.get('XDG_CURRENT_DESKTOP', '') or os.environ.get('XDG_SESSION_DESKTOP', '') or os.environ.get('DESKTOP_SESSION', '')
    ver     = run("hyprctl version 2>/dev/null | grep -oP 'v[0-9]+\\.[0-9]+\\.[0-9]+' | head -1")
    if ver:
        label = f"Hyprland {ver} ({session.capitalize()})" if session else f"Hyprland {ver}"
    elif de:
        label = f"{de} ({session.capitalize()})" if session else de
    else:
        label = session.capitalize() or "Unknown"

    # Active monitors — try Hyprland → xrandr → wlr-randr → fallback
    displays = ""
    try:
        raw = subprocess.check_output("hyprctl monitors -j", shell=True, stderr=subprocess.DEVNULL).decode()
        monitors = json.loads(raw)
        displays = "  ".join(f"{m['name']}: {m['width']}x{m['height']}@{round(m['refreshRate'])}Hz" for m in monitors)
    except Exception:
        pass

    if not displays:
        xrandr = run("xrandr 2>/dev/null | awk '/connected/ && /[0-9]+x[0-9]+/{match($0,/[0-9]+x[0-9]+/); print $1\": \"substr($0,RSTART,RLENGTH)}'")
        if xrandr and xrandr != "N/A":
            displays = "  ".join(xrandr.splitlines())

    if not displays:
        wlr = run("wlr-randr 2>/dev/null | awk '/^[A-Z]/{name=$1} /current/{print name\": \"$1}'")
        if wlr and wlr != "N/A":
            displays = "  ".join(wlr.splitlines())

    if not displays:
        displays = os.environ.get("DISPLAY") or os.environ.get("WAYLAND_DISPLAY") or "N/A"

    driver = run("lsmod | awk '/^amdgpu/{print \"amdgpu\"}' | head -1") or \
             run("lsmod | awk '/^nvidia/{print \"nvidia\"}' | head -1") or "N/A"
    return [
        ("󰉼", "Session",  label),
        ("󰍹", "Display",  displays),
        ("󰍹", "G-Driver", driver),
    ]

def terminal_info():
    # shell
    _sh = os.environ.get("SHELL", "")
    shell = run(f"{_sh} --version 2>/dev/null | head -1") if _sh else "N/A"
    if shell in ("N/A", ""):
        shell = os.path.basename(_sh) if _sh else "N/A"

    # terminal — try common ones in order
    term = (run("kitty --version 2>/dev/null | head -1 | awk '{print $1\" \"$2}'")         or
            run("alacritty --version 2>/dev/null | head -1 | awk '{print $1\" \"$2}'")     or
            run("wezterm --version 2>/dev/null | head -1")                                  or
            run("foot --version 2>/dev/null | head -1")                                     or
            run("xfce4-terminal --version 2>/dev/null | head -1 | awk '{print $1\" \"$2}'") or
            run("konsole --version 2>/dev/null | head -1")                                  or
            run("gnome-terminal --version 2>/dev/null | head -1 | awk '{print $1\" \"$NF}'") or
            run("tilix --version 2>/dev/null | head -1")                                    or
            os.environ.get("TERM_PROGRAM", "") or os.environ.get("TERM", "N/A"))

    # font — try common terminal configs
    font = (run("grep -E '^font_family' ~/.config/kitty/kitty.conf 2>/dev/null | awk '{$1=\"\"; print $0}' | xargs")                          or
            run("grep -E 'family' ~/.config/alacritty/alacritty.toml 2>/dev/null | head -1 | cut -d'\"' -f2")                                 or
            run("grep -E 'family' ~/.config/alacritty/alacritty.yml 2>/dev/null | head -1 | awk '{print $2}' | tr -d '\"'")                   or
            run("grep -E 'font' ~/.config/foot/foot.ini 2>/dev/null | head -1 | cut -d= -f2 | awk '{print $1}'")                              or
            run("grep -rE 'font-family' ~/.config/wezterm/wezterm.lua 2>/dev/null | head -1 | cut -d'\"' -f2"))

    # packages — detect available package managers
    pkg_parts = []
    for cmd, label in [
        ("pacman -Q 2>/dev/null | wc -l",           "pacman"),
        ("dpkg -l 2>/dev/null | grep -c '^ii'",     "dpkg"),
        ("rpm -qa 2>/dev/null | wc -l",             "rpm"),
        ("apk list --installed 2>/dev/null | wc -l","apk"),
    ]:
        n = run(cmd)
        if n and n not in ("N/A", "0", ""):
            pkg_parts.append(f"{n} ({label})")
    flat = run("flatpak list 2>/dev/null | wc -l")
    if flat and flat not in ("N/A", "0", ""):
        pkg_parts.append(f"{flat} (flatpak)")
    snap = run("snap list 2>/dev/null | tail -n +2 | wc -l")
    if snap and snap not in ("N/A", "0", ""):
        pkg_parts.append(f"{snap} (snap)")
    packages = ", ".join(pkg_parts) if pkg_parts else "N/A"

    return [
        ("󰈺", "Shell",     shell),
        ("󰆍", "Terminal",  term),
        ("󰛖", "Term Font", font.strip() if font else "N/A"),
        ("󰏘", "Packages",  packages),
    ]

